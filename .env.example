# Gemini Developer API live smoke
# Copy this file to .env and replace placeholders locally. Never commit .env.
RUN_GEMINI_LIVE_TESTS=0
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash

# Gemini Enterprise Interactions live smoke
# Local runs use Google Application Default Credentials; CI uses keyless WIF.
RUN_GEMINI_ENTERPRISE_LIVE_TESTS=0
GEMINI_ENTERPRISE_PROJECT=
GEMINI_ENTERPRISE_LOCATION=
GEMINI_ENTERPRISE_MODEL=
GEMINI_ENTERPRISE_API_VERSION=v1beta1

# GitHub environment variables used only by the Enterprise CI workflow
GCP_WORKLOAD_IDENTITY_PROVIDER=
GCP_SERVICE_ACCOUNT=
